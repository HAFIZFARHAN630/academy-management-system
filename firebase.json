{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma",        "value": "no-cache" },
          { "key": "Expires",       "value": "0" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/registration.html", "destination": "/registration.html" },
      { "source": "/calendar",          "destination": "/admin/calendar.html" },
      { "source": "**",                "destination": "/index.html" }
    ]
  }
}
