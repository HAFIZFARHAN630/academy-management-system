{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "https://clicktake-academy.web.app/",
    "distDir": "https://clicktake-academy.web.app/",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Academy Management System",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.clicktake.academy",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [],
      "externalBin": [],
      "copyright": "Copyright © 2026 ClickTake Technologies",
      "category": "Education",
      "shortDescription": "Academy Management System Desktop App",
      "longDescription": "A lightweight desktop wrapper for the Academy Management System."
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://* data:; connect-src 'self' https://*; script-src 'self' 'unsafe-inline' https://*; style-src 'self' 'unsafe-inline' https://*;"
    },
    "window": [
      {
        "fullscreen": false,
        "height": 720,
        "resizable": true,
        "title": "Academy Management System",
        "width": 1280,
        "center": true,
        "decorations": true
      }
    ]
  }
}
