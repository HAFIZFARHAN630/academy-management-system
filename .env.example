# Academy Management System — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git — only commit .env.example

# ─── Core ────────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change_this_to_a_long_random_string
ACADEMY_NAME=ClickTake Academy
SESSION_TIMEOUT=86400
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
FRONTEND_URL=http://localhost:3001

# ─── Email Service ────────────────────────────────────────────────────────────
# Options: 'gmail' (primary) or 'resend' (fallback)
# Service auto-falls back to the other if primary fails
EMAIL_PROVIDER=gmail
EMAIL_FROM=ClickTake Academy <noreply@yourdomain.com>

# Gmail Setup:
# 1. Go to Google Account → Security → 2-Step Verification → ON
# 2. Then go to: Security → App Passwords → Create one for "Mail"
# 3. Use the 16-char App Password here (NOT your Gmail login password)
GMAIL_USER=your_academy_email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Resend Setup:
# 1. Sign up at https://resend.com (free: 3,000 emails/month)
# 2. API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudinary (File/Image Storage) ─────────────────────────────────────────
# 1. Sign up at https://cloudinary.com (free: 25 GB storage)
# 2. Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key_number
CLOUDINARY_API_SECRET=your_api_secret_string
CLOUDINARY_FOLDER=academy

# ─── Firebase FCM (Push Notifications) ───────────────────────────────────────
# 1. Go to https://console.firebase.google.com → Your Project
# 2. Project Settings → Service Accounts → Generate New Private Key
# 3. Download the JSON file
#
# FOR PRODUCTION (Render): Paste entire JSON content as one line below
FIREBASE_SERVICE_ACCOUNT_JSON=
#
# FOR LOCAL DEV: Uncomment and set path to downloaded JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#
# Project ID: Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id
